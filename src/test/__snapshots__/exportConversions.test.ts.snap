`;

exports[`technical document export fixture > locks Typst export for technical blocks 1`] = `
"// Admonition helper
#let admonition(title: "", color: blue, body) = block(
  fill: color.lighten(90%),
  stroke: (left: 3pt + color),
  inset: 10pt,
  radius: (right: 4pt),
  width: 100%,
  [*#title* \\ #body]
)

= System Overview
See @fig:system
  and inline math $E=mc^2$.

#admonition(title: "Warning", color: yellow)[Use patch review before applying changes.]
\`\`\`ts
const phase = "ast";
\`\`\`
// Mermaid diagram (not natively supported in Typst)
// \`\`\`mermaid
// graph TD
// A-->B
// \`\`\`
$ \\int_0^1 x^2 dx $
#image("diagram.png", alt: "system diagram")
#figure(caption: [System architecture]) 
Detailed note
  #footnote[Footnote text]

Footnote text
"
`;
