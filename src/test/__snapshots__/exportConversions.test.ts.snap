exports[`technical document export fixture > locks LaTeX export for technical blocks 1`] = `
"\\section{System Overview}

  See Figure 1
  and inline math $E=mc^2$.

% admonition-meta: type=warning color=yellow icon=alert-triangle
\\begin{admonitionbox}[Warning]{yellow!80!black}
Use patch review before applying changes.
\\end{admonitionbox}

\\begin{lstlisting}[language=ts]
const phase = "ast";
\\end{lstlisting}

% begin-mermaid
% mermaid: graph TD
% mermaid: A-->B
% end-mermaid

\\[
\\int_0^1 x^2 dx
\\]

\\begin{figure}[H]
  \\centering
  \\includegraphics[width=0.8\\textwidth]{diagram.png}
  \\caption{system diagram}
  \\label{fig:figure1}
\\end{figure}

Figure 1: System architecture

  Detailed note
  \\footnote{Footnote text}"
`;

exports[`technical document export fixture > locks RST export for technical blocks 1`] = `
