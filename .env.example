# Local development
VITE_APP_PROFILE=desktop
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=urban-dds
GOOGLE_CLOUD_LOCATION=asia-northeast3
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
AI_SERVER_PORT=8787
AI_ALLOWED_ORIGIN=http://localhost:8080
WORKSPACE_FRONTEND_ORIGIN=http://localhost:8080
VITE_AI_API_BASE_URL=http://localhost:8787

# Cloud Run notes
# - Cloud Run injects PORT automatically, so do not set AI_SERVER_PORT there.
# - Set AI_ALLOWED_ORIGIN to your deployed frontend origin.
# - Set VITE_AI_API_BASE_URL to your deployed Cloud Run AI service URL.
#
# Example deployed values:
# VITE_APP_PROFILE=web
# AI_ALLOWED_ORIGIN=https://your-frontend-domain
# WORKSPACE_FRONTEND_ORIGIN=https://your-frontend-domain
# VITE_AI_API_BASE_URL=https://your-cloud-run-service-url
# GOOGLE_OAUTH_REDIRECT_URI=https://your-cloud-run-service-url/api/auth/google/callback
#
# Vertex AI local auth:
# - Run `gcloud auth application-default login`
# - Ensure the active ADC identity can access Vertex AI in GOOGLE_CLOUD_PROJECT
# - GEMINI_MODEL must be a valid Vertex AI Gemini model id
# - GEMINI_FALLBACK_MODEL is used only when the primary model fails due to model/quota errors

# Google Workspace integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8787/api/auth/google/callback
GOOGLE_WORKSPACE_SCOPES=openid email profile https://www.googleapis.com/auth/drive.readonly https://www.googleapis.com/auth/drive.metadata.readonly https://www.googleapis.com/auth/documents
WORKSPACE_STATE_PATH=.data/docsy-workspace-state.json
WORKSPACE_DB_PATH=
