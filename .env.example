# Local development
VITE_APP_PROFILE=desktop
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=urban-dds
GOOGLE_CLOUD_LOCATION=asia-northeast3
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
AI_SERVER_PORT=8787
AI_ALLOWED_ORIGIN=http://localhost:8080
AI_MAX_REQUEST_BYTES=2097152
AI_DIAGNOSTICS_TOKEN=
WORKSPACE_FRONTEND_ORIGIN=http://localhost:8080
VITE_AI_API_BASE_URL=http://localhost:8787

# Cloud Run notes
# - Cloud Run injects PORT automatically, so do not set AI_SERVER_PORT there.
# - Set AI_ALLOWED_ORIGIN to your deployed frontend origin.
# - Set VITE_AI_API_BASE_URL to your deployed Cloud Run AI service URL.
#
# Example deployed values:
# VITE_APP_PROFILE=web
# AI_ALLOWED_ORIGIN=https://app.your-domain.dev
# AI_MAX_REQUEST_BYTES=2097152
# AI_DIAGNOSTICS_TOKEN=generate-a-random-token-for-internal-health
# WORKSPACE_FRONTEND_ORIGIN=https://app.your-domain.dev
# VITE_AI_API_BASE_URL=https://api.your-domain.dev
# GOOGLE_OAUTH_REDIRECT_URI=https://api.your-domain.dev/api/auth/google/callback
# GOOGLE_OAUTH_PUBLISHING_STATUS=production
#
# Vertex AI local auth:
# - Run `gcloud auth application-default login`
# - Ensure the active ADC identity can access Vertex AI in GOOGLE_CLOUD_PROJECT
# - GEMINI_MODEL must be a valid Vertex AI Gemini model id
# - GEMINI_FALLBACK_MODEL is used only when the primary model fails due to model/quota errors

# Google Workspace integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8787/api/auth/google/callback
GOOGLE_OAUTH_PUBLISHING_STATUS=testing
GOOGLE_WORKSPACE_SCOPE_PROFILE=restricted
# Optional explicit override. When set, it overrides GOOGLE_WORKSPACE_SCOPE_PROFILE.
GOOGLE_WORKSPACE_SCOPES=
WORKSPACE_STATE_PATH=
WORKSPACE_DB_PATH=

# TeX service hardening
TEX_MAX_REQUEST_BYTES=400000
# Keep full LaTeX document wrappers enabled for deployed LaTeX mode.
# Restricted file/process primitives stay blocked unless explicitly enabled.
TEX_ALLOW_RAW_DOCUMENT=true
TEX_ALLOW_RESTRICTED_COMMANDS=false
TEX_ALLOWED_PACKAGES=amsmath,amssymb,amsthm,array,booktabs,caption,enumitem,etoolbox,fancyhdr,float,fontspec,geometry,graphicx,hyperref,inputenc,listings,longtable,makecell,mathtools,multirow,setspace,soul,tabularx,tcolorbox,titlesec,ulem,xcolor,xeCJK
